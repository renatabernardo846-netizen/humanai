GEMINI_API_KEY=sua_chave_gemini_aqui

# ── WHATSAPP BUSINESS API (Meta) ─────────────
# Obtenha em: https://developers.facebook.com
WHATSAPP_TOKEN=seu_token_whatsapp_aqui
WHATSAPP_VERIFY_TOKEN=humanai_verify_2026
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id

# ── INSTAGRAM GRAPH API (Meta) ────────────────
INSTAGRAM_TOKEN=seu_token_instagram_aqui
INSTAGRAM_VERIFY_TOKEN=humanai_ig_verify_2026

# ── SEGURANÇA ─────────────────────────────────
API_SECRET_KEY=humanai_secret_key_mude_isso
